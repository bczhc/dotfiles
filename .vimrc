set number
set encoding=utf-8
set fileencodings=utf-8
set scrolloff=2
set showmatch
set shiftwidth=4
set tabstop=4
set autoread
set expandtab
set backspace=indent,eol,start
set hlsearch

syntax enable
filetype plugin indent on

nnoremap <M-h> <C-w>h
nnoremap <M-j> <C-w>j
nnoremap <M-k> <C-w>k
nnoremap <M-l> <C-w>l
