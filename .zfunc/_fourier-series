#compdef fourier-series

autoload -U is-at-least

_fourier-series() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-i+[Numerical integration method]: :(trapezoid left-rectangle right-rectangle simpson simpson38 boole)' \
'--integrator=[Numerical integration method]: :(trapezoid left-rectangle right-rectangle simpson simpson38 boole)' \
'-d+[Input data set file (if not provided, use a built-in test data set)]: :_files' \
'--data=[Input data set file (if not provided, use a built-in test data set)]: :_files' \
'-h[Print help information]' \
'--help[Print help information]' \
'::epicycle-count:' \
'::period:' \
'::thread-count:' \
'::integral-segments:' \
&& ret=0
}

(( $+functions[_fourier-series_commands] )) ||
_fourier-series_commands() {
    local commands; commands=()
    _describe -t commands 'fourier-series commands' commands "$@"
}

_fourier-series "$@"
