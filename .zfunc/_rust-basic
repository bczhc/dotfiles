#compdef rust-basic

autoload -U is-at-least

_rust-basic() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
'::arg1:_command_names -e' \
&& ret=0
}

(( $+functions[_rust-basic_commands] )) ||
_rust-basic_commands() {
    local commands; commands=()
    _describe -t commands 'rust-basic commands' commands "$@"
}

if [ "$funcstack[1]" = "_rust-basic" ]; then
    _rust-basic "$@"
else
    compdef _rust-basic rust-basic
fi
