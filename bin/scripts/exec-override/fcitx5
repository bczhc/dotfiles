#!/bin/bash

set -e

BIN=/usr/local/bin/fcitx5

# Bug https://github.com/fcitx/fcitx5/issues/1566 is annoying. Fcitx5 being accidentally interrupted can trigger
# this. Work around it.
cd ~/.config/fcitx5
cp -a profile.bak profile
cd -

name="`date '+%Y-%m-%d %H:%M:%S'`"
dir=~/Documents/my-log/fcitx5
mkdir -p "$dir" 2>/dev/null || true
path="$dir/$name"

notify-send 'Fcitx5 logger started' -t 2000

"$BIN" "$@" --verbose=rime=5 2>&1 | tee "$path"
#/usr/local/bin/fcitx5 "$@" --verbose=rime=5 2>&1 | tee "$path"
