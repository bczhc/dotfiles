#!/bin/bash

# https://github.com/niri-wm/niri/discussions/3331#discussioncomment-15974148
insert_to_new() {
    # Fetch the workspaces JSON once to prevent race conditions
    WS_JSON=$(niri msg -j workspaces)

    CURR_IDX=$(echo "$WS_JSON" | jq -r '.[] | select(.is_focused == true) | .idx')
    CURR_OUT=$(echo "$WS_JSON" | jq -r '.[] | select(.is_focused == true) | .output')

    LAST_WS=$(echo "$WS_JSON" | jq -r "[.[] | select(.output == \"$CURR_OUT\")] | length")
    NEW_WSPACE=$((CURR_IDX + "$1"))

    niri msg action set-workspace-name _tempws --workspace "$LAST_WS"
    niri msg action move-workspace-to-index "$NEW_WSPACE" --reference _tempws 
    if [ "$2" = "move" ]; then
        niri msg action move-column-to-workspace _tempws
    elif [ "$2" == "focus" ]; then
        niri msg action focus-workspace _tempws
    else
        echo "Unknown mode: $2"
        exit 1
    fi
    niri msg action unset-workspace-name _tempws
}

[ $# -ne 2 ] && echo 'Usage: cmd <offset> move|focus' && exit 1

offset="$1"
mode="$2"

insert_to_new "$offset" "$mode"
