#!/bin/bash

## My niri screenshout utility script.
##
## Assisted-by: Gemini:Fast

set -e

export RUST_LOG=info

curr_dir="$(dirname "$0")"

failure() {
    notify-send -u critical 'Screenshot Failed!! Code: '"$1"; exit 1
}

interactive_canceled() {
    #notify-send -u low 'Screenshot Canceled.'; exit 0
    exit 0
}

notify_has_left_tmp_ss() {
    notify-send -u critical "Previous temp screenshot exists." "$1"
}

check_left_tmp_ss() {
    local result="$(fd '^niri-ss' /tmp || true)"
    [ ! -z "$result" ] && notify_has_left_tmp_ss "$result"
    return 0
}

DATE_STR=$(date "+%Y-%m-%d_%H-%M-%S")
temp_file_uuid=$(uuidgen)
TEMP_FILE="/tmp/niri-ss-$temp_file_uuid.png"
SAVE_DIR="/home/bczhc/Screenshots"

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo 'Usage:'
    echo "  $0"
    echo "  $0 --area"
    echo "  $0 --help"
    exit 0
fi

area_mode=0
[[ "$1" == "--area" ]] && area_mode=1

mkdir -p "$SAVE_DIR"

#check_left_tmp_ss

comment_value="$(/home/bczhc/bin/scripts/niri/ipc-msgs)"

# 截图
if [[ "$area_mode" -eq 1 ]]; then
    niri-ss-blocked area "$TEMP_FILE" || interactive_canceled
else
    niri-ss-blocked screen "$TEMP_FILE" || failure 1
fi

[ -f "$TEMP_FILE" ] || failure 2.1
# fs上做备份，万一后续处理出问题
temp_file_on_fs="$SAVE_DIR"/$temp_file_uuid.png
cp -av "$TEMP_FILE" "$temp_file_on_fs"

# 2. 安全地锁定目标文件名
TARGET_FILE="$SAVE_DIR/$DATE_STR.png"
COUNTER=1

until (set -o noclobber; > "$TARGET_FILE") 2> /dev/null; do
    TARGET_FILE="$SAVE_DIR/${DATE_STR}_${COUNTER}.png"
    ((COUNTER++))
done

# 到这里为止，$TARGET_FILE 已经是一个被我们“占坑”成功的空文件了

#if [ "$1" != "no-notify" ]; then
#    notify-send -t 1000 'Screenshot has been grabbed: '"$(basename "$TARGET_FILE")"
#fi

# 3. 使用 ffmpeg 压缩并覆盖那个空文件
# 注意：使用 -y 强制覆盖，因为我们上面已经创建了空文件
# 这一步可能会很耗时
ffmpeg -v error -i "$TEMP_FILE" -pred mixed -compression_level 9 -y "$TARGET_FILE" || failure 3

exiftool -overwrite_original_in_place -Comment="$comment_value" "$TARGET_FILE" || failure 4

rm -v "$TEMP_FILE" "$temp_file_on_fs"

echo "Done: $TARGET_FILE"
