#!/bin/bash

# xwayland server for gsr-ui
wl-paper --layer overlay --exclusive-zone -1 --keyboard-interactivity none xwayland-satellite :1 &
# xwayland server for gsr-notify
wl-paper --layer overlay --input-passthrough --keyboard-interactivity none xwayland-satellite :2 &

sleep 1

DISPLAY=:1 gsr-ui &
DISPLAY=:2 ~/code/simple-overlay/ft
