#!/bin/bash

set -e

GRIM_BIN=grim
#GRIM_BIN=/bin/grim
curr_dir="$(dirname "$0")"

function failure() {
    notify-send -t 10000 'Screenshot Failed!!'; exit 1
}

wait_and_verify_file() {
    local FILE_PATH="$1"
    local START_TIME=$(date +%s%N) # 获取纳秒级起始时间
    local TIMEOUT_NS=2000000000    # 2秒

    # 阶段 1: 等待文件存在
    while [ ! -f "$FILE_PATH" ]; do
        local CURRENT_TIME=$(date +%s%N)
        if (( CURRENT_TIME - START_TIME > TIMEOUT_NS )); then
            echo "Error: Timeout waiting for file to exist." >&2
            return 1
        fi
        # 可选：sleep 0.05 以降低 CPU 占用，真正的 spin loop 则不加 sleep
    done

    # 阶段 2: 使用 ffmpeg 验证文件完整性
    # 只要 ffmpeg 返回非 0（文件损坏或未写完），就继续重试直到超时
    while ! ffmpeg -v error -i "$FILE_PATH" -f null - >/dev/null 2>&1; do
        local CURRENT_TIME=$(date +%s%N)
        if (( CURRENT_TIME - START_TIME > TIMEOUT_NS )); then
            echo "Error: Timeout waiting for file to be valid (ffmpeg check failed)." >&2
            return 1
        fi
        sleep 0.1
    done
    return 0
}

# 使用示例
# check_and_verify_file "/path/to/your/video.mp4"

DATE_STR=$(date "+%Y-%m-%d_%H-%M-%S")
TEMP_FILE="/tmp/$(uuidgen).png"
SAVE_DIR="/home/bczhc/Screenshots"

mkdir -p "$SAVE_DIR"

# 截图
niri msg action screenshot-screen -d true -p true --path "$TEMP_FILE"
wait_and_verify_file "$TEMP_FILE"

# 2. 安全地锁定目标文件名
TARGET_FILE="$SAVE_DIR/$DATE_STR.png"
COUNTER=1

until (set -o noclobber; > "$TARGET_FILE") 2> /dev/null; do
    TARGET_FILE="$SAVE_DIR/${DATE_STR}_${COUNTER}.png"
    ((COUNTER++))
done

# 到这里为止，$TARGET_FILE 已经是一个被我们“占坑”成功的空文件了

#if [ "$1" != "no-notify" ]; then
#    notify-send -t 1000 'Screenshot has been grabbed: '"$(basename "$TARGET_FILE")"
#fi

# 3. 使用 ffmpeg 压缩并覆盖那个空文件
# 注意：使用 -y 强制覆盖，因为我们上面已经创建了空文件
ffmpeg -v error -i "$TEMP_FILE" -pred mixed -compression_level 9 -y "$TARGET_FILE" || failure

comment_value="$("$curr_dir"/niri-msgs)"
exiftool -overwrite_original_in_place -Comment="$comment_value" "$TARGET_FILE" || failure

# 4. 清理并通知
rm "$TEMP_FILE"

echo "Done: $TARGET_FILE"
