#!/bin/bash

## Blocked version of niri msg action screenshot*.
##
## Assisted-by: Gemini:Fast

export RUST_LOG=info

niri_screenshot_blocked() {
    local fifo=$(mktemp -u)
    mkfifo "$fifo"

    niri msg -j event-stream | jq --unbuffered -r '.ScreenshotCaptured.path // empty' > "$fifo" &
    local listener_pid=$!

    niri msg action screenshot-screen -d true -p true --path "$1"

    local captured_path
    read -r captured_path < "$fifo"

    kill "$listener_pid" 2>/dev/null
    rm -f "$fifo"

    echo "$captured_path"
}

niri_area_screenshot_blocked() {
    local fifo=$(mktemp -u)
    mkfifo "$fifo"

    (
        niri msg -j event-stream | jq --unbuffered -r '
            if .ScreenshotUiChanged?.event == "Open" then "SIGNAL_OPEN"
            elif .ScreenshotUiChanged?.event == "Cancel" then "SIGNAL_CANCEL"
            elif .ScreenshotCaptured?.path then .ScreenshotCaptured.path
            else empty end
        ' > "$fifo"
    ) &
    local listener_pid=$!

    trap "kill $listener_pid 2>/dev/null; rm -f $fifo" EXIT

    niri msg action screenshot -p true --path "$1"

    local captured_result="Canceled."
    local is_ui_open=false

    while read -r line; do
        case "$line" in
            "SIGNAL_OPEN")
                # 只有收到这个，才开始正式生效
                is_ui_open=true
                ;;
            "SIGNAL_CANCEL")
                # 必须是 UI 打开过后的 Cancel 才有效
                if [[ "$is_ui_open" == "true" ]]; then
                    captured_result="Canceled."
                    break
                fi
                ;;
            *)
                if [[ -n "$line" ]]; then
                    captured_result="$line"
                    break
                fi
                ;;
        esac
    done < "$fifo"

    kill "$listener_pid" 2>/dev/null
    rm -f "$fifo"
    trap - EXIT

    echo "$captured_result"
    [[ "$captured_result" == "Canceled." ]] && return 1
    return 0
}

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> <path>

A blocked wrapper for Niri screenshots that waits for the capture to complete.

Commands:
  screen    Capture the entire screen (-d true -p true)
  area      Interactively select a window or area to capture (-p true)

Arguments:
  path      Absolute path to save the screenshot.
EOF
}

if [[ $# -lt 2 ]]; then
    usage
    exit 1
fi

case "$1" in
    screen)
        niri_screenshot_blocked "$2"
        ;;
    area)
        niri_area_screenshot_blocked "$2"
        ;;
    -h|--help|help)
        usage
        exit 0
        ;;
    *)
        echo "Error: Unknown command '$1'"
        usage
        exit 1
        ;;
esac
