#!/bin/bash

[ $# -eq 0 ] && echo 'Usage: cmd low|high|normal' && exit 1

dir="$(dirname "$0")"

set_clock_memory() {
    sudo "$dir"/nvidia-clock-sudo m "$1" "$2"
}

set_clock_graphics() {
    sudo "$dir"/nvidia-clock-sudo g "$1" "$2"
}

[ "$1" == "low" ] && set_clock_memory 405 405 && set_clock_graphics 472 472 && \
    notify-send -u low 'Nvidia clock: low' && exit 0

[ "$1" == "high" ] && set_clock_memory 7001 7001 && set_clock_graphics 2100 2100 && \
    notify-send -u low 'Nvidia clock: high' && exit 0

[ "$1" == "normal" ] && set_clock_memory 405 7001 && set_clock_graphics 472 2100 && \
    notify-send -u low 'Nvidia clock: normal' && exit 0

echo 'Unknown usage' && exit 1
