#!/bin/env ruby

require 'json'

# 执行命令并实时读取输出
# -s put 指向特定列，使用 unbuffered 模式确保实时性
command = "nvidia-smi dmon -s put"

IO.popen(command) do |io|
  headers = nil
  
  io.each_line do |line|
    line.strip!
    # 跳过空行或只包含横杠的装饰行
    next if line.empty? || line.start_with?("# ---")
    
    # 匹配表头行 (以 # gpu 开头)
    if line =~ /^#\s+gpu/
      # 清理 # 并分割，提取出具体的列名
      headers = line.sub('#', '').split
      next
    end

    # 跳过辅助列名行 (如 Idx, W, C...)
    next if line.start_with?("# Idx")

    # 此时是数据行
    if headers
      values = line.split
      # 将数据与表头配对
      data = headers.zip(values).to_h
      
      # 注入毫秒级时间戳
      # (Time.now.to_f * 1000).to_i 得到当前 Unix 时间戳（毫秒）
      data["timestamp"] = (Time.now.to_f * 1000).to_i
      
      # 输出 JSONL (每一行是一个 JSON 对象)
      puts data.to_json
      STDOUT.flush # 确保立即输出，不被缓存
    end
  end
end
