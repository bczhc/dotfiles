home_ip_prefix='192.168.124.'
ext_ip=192.168.124.126

count=`ip -c=never addr show dev enp47s0 | rg -F 'inet '"$home_ip_prefix" | wc -l`
[ $count -ne 1 ] && exit 0

count=`ip -c=never addr show dev enp47s0 | rg -F 'inet '"$ext_ip" | wc -l`
[ $count -ne 0 ] && exit 0

echo 'Add an extra IP: '$ext_ip

ip addr add "$ext_ip"/24 dev enp47s0
