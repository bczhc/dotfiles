From 2ada5e00c4aba7ac4b79119d2ed039bc1950e357 Mon Sep 17 00:00:00 2001
From: Zhai Can <bczhc0@126.com>
Date: Thu, 23 Jul 2026 16:11:27 +0800
Subject: [PATCH] Bug 2028505 - Fix spurious fake keydown events in Wayland key
 snooper mode
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

On Wayland with zwp_text_input_v3, some IMEs (e.g. Fcitx5) send
preedit_string on every key event while composing — both key press and
key release. Since key press events are consumed by the IME and never
reach Firefox as GDK events, the key snooper path in
MaybeDispatchKeyEventAsProcessedByIME always dispatches a fake eKeyDown
for each preedit_changed signal, regardless of whether the underlying
physical event was a key press or key release. This caused four
problems:

1. Character key release: An extra KEYDOWN(Process) was dispatched on
   keyup because the preedit_string re-sent on key release was
   indistinguishable from the one sent on key press.

2. Esc/Enter to dismiss IME: Two KEYDOWN(Process) events were
   dispatched — one from the compositionchange to empty preedit and
   another from the subsequent composition commit — for a single
   physical key press that never reached Firefox.

3. Arrow keys during composition: If IME did not change the preedit
   string or clause attributes on candidate navigation, the arrow key
   press was incorrectly suppressed as if it were a key release.

4. Auto-commit mode: When commit_string is followed immediately by a
   new preedit_string from the same key press, both produced a fake
   KEYDOWN, double-counting a single key press.

The fix handles all four cases:

- In OnChangeCompositionNative, when in key snooper mode with no GDK
  event available, compare the new preedit against the last dispatched
  state. If both the composition string and TextRange array (clause
  structure, caret position, highlighting) are identical, skip at most
  one dispatch — the first skip catches the key release, and the second
  consecutive identical preedit is recognized as a new key press (for
  arrow keys or re-typing).

- When the preedit becomes empty (IME dismissal), still dispatch the
  compositionchange event so the page can clear its preedit UI, but
  suppress the fake keydown — the subsequent preedit_end -> commit path
  produces exactly one KEYDOWN.

- Track when a fake KEYDOWN was dispatched for a commit in key snooper
  mode via mJustDispatchedFakeKeyDownForCommitInSnoopMode, and suppress
  the immediately following composition start's fake KEYDOWN. The flag
  is cleared in OnKeyEvent so separate key presses are unaffected.

Differential Revision: https://phabricator.services.mozilla.com/D313440

Based on patch by Martin <stransky@redhat.com>.

Generated-by: Claude:deepseek-v4-pro; not reviewed
Fixes: https://bugzilla.mozilla.org/show_bug.cgi?id=2028505
---
 widget/gtk/IMContextWrapper.cpp | 92 ++++++++++++++++++++++++++++++---
 widget/gtk/IMContextWrapper.h   | 13 +++++
 2 files changed, 99 insertions(+), 6 deletions(-)

diff --git a/widget/gtk/IMContextWrapper.cpp b/widget/gtk/IMContextWrapper.cpp
index ec1b28332a04..6141a51041f6 100644
--- a/widget/gtk/IMContextWrapper.cpp
+++ b/widget/gtk/IMContextWrapper.cpp
@@ -779,6 +779,11 @@ KeyHandlingState IMContextWrapper::OnKeyEvent(
     return KeyHandlingState::eNotHandled;
   }
 
+  // A GDK key event arriving means a new real key press or release.
+  // Clear the auto-commit suppression flag so that a new key press
+  // after a commit will get its fake keydown.
+  mJustDispatchedFakeKeyDownForCommitInSnoopMode = false;
+
   // Even if old IM context has composition, key event should be sent to
   // current context since the user expects so.
   GtkIMContext* currentContext = GetCurrentContext();
@@ -1796,6 +1801,50 @@ void IMContextWrapper::OnChangeCompositionNative(GtkIMContext* aContext) {
     return;  // Don't start the composition with empty string.
   }
 
+  // In key snooper mode (Wayland), we receive preedit_changed from key
+  // releases as well as key presses. Detect and skip redundant dispatches.
+  if (mIsKeySnooped && !mProcessingKeyEvent && mPostingKeyEvents.IsEmpty()) {
+    if (compositionString.IsEmpty()) {
+      // The preedit is being cleared (e.g. Esc/Enter to dismiss IME).
+      // Don't skip DispatchCompositionChangeEvent — the page needs the
+      // compositionupdate event to clear its preedit UI. The fake keydown
+      // will be suppressed in DispatchCompositionChangeEvent instead.
+      mDispatchedCompositionString.Truncate();
+    } else if (compositionString.Equals(mDispatchedCompositionString)) {
+      // Same composition string as last time. Compare text ranges to
+      // detect whether the IME state actually changed (e.g. arrow key
+      // candidate navigation changes clause highlighting) or whether
+      // this is an unchanged preedit from a key release.
+      RefPtr<TextRangeArray> currentRanges =
+          CreateTextRangeArray(aContext, compositionString);
+      if (mLastDispatchedTextRangeArray) {
+        bool rangesIdentical =
+            currentRanges->Length() ==
+            mLastDispatchedTextRangeArray->Length();
+        if (rangesIdentical) {
+          for (uint32_t i = 0; i < currentRanges->Length(); i++) {
+            if (!currentRanges->ElementAt(i).Equals(
+                    mLastDispatchedTextRangeArray->ElementAt(i))) {
+              rangesIdentical = false;
+              break;
+            }
+          }
+        }
+        if (rangesIdentical) {
+          // At most one skip: if we already skipped the last identical
+          // preedit (key release), this second identical one is from a
+          // new key press (e.g. arrow key navigation, or re-typing the
+          // same letter after the key was released).
+          if (!mSkippedLastIdenticalPreedit) {
+            mSkippedLastIdenticalPreedit = true;
+            return;
+          }
+        }
+      }
+    }
+  }
+  mSkippedLastIdenticalPreedit = false;
+
   // Be aware, widget can be gone
   DispatchCompositionChangeEvent(aContext, compositionString);
 }
@@ -2168,6 +2217,16 @@ bool IMContextWrapper::MaybeDispatchKeyEventAsProcessedByIME(
     bool dispatchFakeKeyDown = false;
     switch (aFollowingEvent) {
       case eCompositionStart:
+        // In auto-commit mode, some IMEs send a commit_string followed by
+        // a new preedit_string from the same key press. If we just
+        // dispatched a fake keydown for the commit, skip the one for
+        // composition start to avoid double-counting the key press.
+        if (mJustDispatchedFakeKeyDownForCommitInSnoopMode) {
+          mJustDispatchedFakeKeyDownForCommitInSnoopMode = false;
+        } else {
+          dispatchFakeKeyDown = true;
+        }
+        break;
       case eCompositionCommit:
       case eCompositionCommitAsIs:
       case eContentCommandInsertText:
@@ -2213,6 +2272,16 @@ bool IMContextWrapper::MaybeDispatchKeyEventAsProcessedByIME(
               ("0x%p   MaybeDispatchKeyEventAsProcessedByIME(), "
                "fake keydown event is dispatched",
                this));
+
+      // If we dispatched a fake keydown for a commit in key snooper mode,
+      // flag it so the immediately following composition start can skip
+      // its fake keydown (auto-commit pattern: same key press produces
+      // both a commit and a new preedit).
+      if (aFollowingEvent == eCompositionCommit ||
+          aFollowingEvent == eCompositionCommitAsIs ||
+          aFollowingEvent == eContentCommandInsertText) {
+        mJustDispatchedFakeKeyDownForCommitInSnoopMode = true;
+      }
     }
   }
 
@@ -2376,12 +2445,20 @@ bool IMContextWrapper::DispatchCompositionChangeEvent(
   }
   // If this composition string change caused by a key press, we need to
   // dispatch eKeyDown or eKeyUp before dispatching eCompositionChange event.
-  else if (!MaybeDispatchKeyEventAsProcessedByIME(eCompositionChange)) {
-    MOZ_LOG(gIMELog, LogLevel::Warning,
-            ("0x%p   DispatchCompositionChangeEvent(), Warning, "
-             "MaybeDispatchKeyEventAsProcessedByIME() returned false",
-             this));
-    return false;
+  // Skip the fake keydown when the preedit becomes empty in key snooper mode:
+  // the subsequent composition commit will produce exactly one keydown.
+  else {
+    bool preeditClearedInSnoopMode =
+        aCompositionString.IsEmpty() && mIsKeySnooped &&
+        !mProcessingKeyEvent && mPostingKeyEvents.IsEmpty();
+    if (!preeditClearedInSnoopMode &&
+        !MaybeDispatchKeyEventAsProcessedByIME(eCompositionChange)) {
+      MOZ_LOG(gIMELog, LogLevel::Warning,
+              ("0x%p   DispatchCompositionChangeEvent(), Warning, "
+               "MaybeDispatchKeyEventAsProcessedByIME() returned false",
+               this));
+      return false;
+    }
   }
 
   RefPtr<TextEventDispatcher> dispatcher = GetTextEventDispatcher();
@@ -2428,6 +2505,7 @@ bool IMContextWrapper::DispatchCompositionChangeEvent(
   // DispatchEvent is async on e10s, so composition rect isn't updated now
   // on tab parent.
   mDispatchedCompositionString = aCompositionString;
+  mLastDispatchedTextRangeArray = rangeArray;
   mLayoutChanged = false;
   mCompositionTargetRange.mOffset =
       mCompositionStart + rangeArray->TargetClauseOffset();
@@ -2584,6 +2662,8 @@ bool IMContextWrapper::DispatchCompositionCommitEvent(
   mCompositionStart = UINT32_MAX;
   mCompositionTargetRange.Clear();
   mDispatchedCompositionString.Truncate();
+  mLastDispatchedTextRangeArray = nullptr;
+  mSkippedLastIdenticalPreedit = false;
   mSelectedStringRemovedByComposition.Truncate();
 
   if (!dispatcher) {
diff --git a/widget/gtk/IMContextWrapper.h b/widget/gtk/IMContextWrapper.h
index 7d942f6abbf4..74f7d90c18b4 100644
--- a/widget/gtk/IMContextWrapper.h
+++ b/widget/gtk/IMContextWrapper.h
@@ -13,6 +13,7 @@
 #include "mozilla/GUniquePtr.h"
 #include "mozilla/Maybe.h"
 #include "mozilla/TextEventDispatcherListener.h"
+#include "mozilla/TextRange.h"
 #include "mozilla/WritingModes.h"
 #include "mozilla/widget/IMEData.h"
 #include "nsCOMPtr.h"
@@ -482,6 +483,18 @@ class IMContextWrapper final : public TextEventDispatcherListener {
   // mIsKeySnooped is set to true if IM uses key snooper to listen key events.
   // In such case, we won't receive key events if IME consumes the event.
   bool mIsKeySnooped;
+  // In key snooper mode, stores the last dispatched TextRange snapshot to
+  // compare against new preedit events. When both string and ranges are
+  // identical, the preedit is from a key release and should be skipped.
+  RefPtr<TextRangeArray> mLastDispatchedTextRangeArray;
+  // Whether the last identical preedit was skipped (key release). Used to
+  // allow at most one skip so that the next identical preedit (e.g. from
+  // an arrow key) is dispatched as a new key press.
+  bool mSkippedLastIdenticalPreedit = false;
+  // Set when a fake keydown is dispatched for a commit in key snooper mode.
+  // The immediately following composition start should skip its fake keydown
+  // to avoid double-dispatch (IME auto-commit pattern).
+  bool mJustDispatchedFakeKeyDownForCommitInSnoopMode = false;
   // mSetInputPurposeAndInputHints is set if `SetInputContext` wants `Focus`
   // to set input-purpose and input-hints.
   bool mSetInputPurposeAndInputHints;

